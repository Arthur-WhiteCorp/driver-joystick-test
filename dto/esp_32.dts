/dts-v1/;
/plugin/;

/ {
	fragment@0 {
		target-path = "/soc";
		__overlay__ {
        		joystick_pwm: joystick-pwm@0 {
				compatible = "TCC,Kronos";
 				pwms = <&pwm 0 5000000 0>; // period of 5 mili
				pwm-names = "clk"; // clk uses pwm
				latch-gpios   = <&gpio 27 0>;
				data-gpios  = <&gpio 22 0>;
				message = "Have a good life";
				status = "okay";
			};
		};
	};
	__overrides__ {
        latch_pin   = <&joystick_pwm>, "latch-gpios:4";
        data_pin  = <&joystick_pwm>, "data-gpios:4";
	pwm_period = <&joystick_pwm>, "pwms:8";
    };
};
